[code_entropy.weights]
# 五类熵汇总为总熵时的维度权重。
# 总和通常应为 1.0。
structure_entropy = 0.3
semantic_entropy = 0.25
behavior_entropy = 0.2
cognition_entropy = 0.15
style_entropy = 0.1

[code_entropy.score_models]

[code_entropy.score_models.health]
# 健康度是总熵的派生指标，不是独立采集值。
# invert_scores=true 表示“总熵越高越差”会被翻转为“健康度越高越好”。
formula_version = "total-entropy-derived-health-v1"
aggregation = "weighted_average"
invert_scores = true
entropy_score_scale = 100.0
output_scale = 100.0
normalize_weights = true
round_digits = 1


[code_entropy.thresholds]
# 旧链路和部分明细展示仍会读取这些阈值。
# 这里主要是辅助阈值，不是五类熵主评分卡。
health_score_excellent = 60
health_score_good = 40
health_score_warning = 20
health_score_danger = 0
common_files_warning = 300
common_files_danger = 400
util_files_warning = 50
naming_variance_warning = 3
naming_variance_danger = 5
todo_warning = 30
todo_danger = 50
missing_javadoc_warning = 0.3
missing_javadoc_danger = 0.5
cyclomatic_complexity_warning = 10
cyclomatic_complexity_danger = 20
method_lines_warning = 50
method_lines_danger = 100
class_lines_warning = 500
class_lines_danger = 1000

[code_entropy.glossary]
# 兼容词典示例：
# standard 为标准词，variants 为允许的别名/历史命名。
# match_position 用于声明这组命名家族按什么位置匹配：
# any=名字任意位置命中；prefix=只匹配前缀家族；suffix=只匹配后缀家族。
# used_by 用于声明词条参与哪些语义规则：
# naming=命名非标准占比，term_gap=术语缺口，naming,term_gap=两者都参与。
# 对项目 glossary.md 来说，只有 standard + description 且没有 variants 的词条默认只参与 term_gap。
# 例如商机根词治理可用 standard="Opp" + match_position="prefix"；
# 任务执行后缀治理可用 standard="Job" + variants=["Task","Work"] + match_position="suffix"。
# 当前 CLI 扫描任意 Java 项目时，语义熵优先使用被扫描项目内的 glossary.md，
# 这里保留为历史兼容示例，不作为术语缺口的生产对比源。

[code_entropy.glossary.opportunity]
standard = "Opp"
variants = ["SaleOpp", "Opportunity"]
match_position = "prefix"

[code_entropy.glossary.job_family]
standard = "Job"
variants = ["Jobs", "Task", "Work"]
match_position = "suffix"

[code_entropy.java]
# Java 语言适配专用配置都放在这里。

[code_entropy.java.strategy]
# strategy 定义“按什么口径理解 Java 项目”。

[code_entropy.java.strategy.controller]
# controller 检测策略。
# 这会影响行为熵扫描范围，以及项目画像是否被识别为 web 项目。
file_name_suffixes = ["Controller"]
class_annotations = ["RestController", "Controller"]
package_keywords = ["controller", "api"]
detect_by_filename = true
detect_by_annotation = true
detect_by_package = true

[code_entropy.java.strategy.return_formats]
# 返回格式识别策略。
# scan_scope=controllers 表示默认只统计 controller 返回；all_java 表示全仓 Java。
scan_scope = "controllers"
wrapper_types = ["ResultVO", "ResponseEntity", "CommonResult", "R"]
map_types = ["Map", "HashMap", "LinkedHashMap"]
collection_types = ["List", "ArrayList", "Set", "HashSet"]
count_scalar_literals = true
count_null_returns = true
count_named_references = true

[code_entropy.java.strategy.project]
# 项目类型判定策略。
# kind=auto 表示自动识别 spring_web / batch_job / plain_java / library。
# degrade_without_controllers=true 表示没有 controller 时允许自动降级，不直接报废行为熵。
kind = "auto"
degrade_without_controllers = true
controllerless_return_scope = "skip"
web_class_annotations = ["RestController", "Controller", "RequestMapping", "GetMapping", "PostMapping", "PutMapping", "DeleteMapping", "PatchMapping"]
web_package_keywords = ["controller", "api", "web"]
batch_class_annotations = ["Scheduled", "KafkaListener", "RabbitListener", "JmsListener"]
batch_package_keywords = ["job", "task", "batch", "schedule", "scheduler", "listener", "consumer"]
batch_class_name_keywords = ["Job", "Task", "Worker", "Listener", "Consumer", "Scheduler"]

[code_entropy.java.strategy.project.discovery]
# 项目画像抽样文件数上限；越大越准，但越慢。
sample_limit = 400

[code_entropy.java.strategy.javadoc]
# JavaDoc 检测口径。
# public_api 是常用生产口径：主要看公共 API 的可读性。
scope = "public_api"
type_visibilities = ["public"]
method_visibilities = ["public"]
type_kinds = ["class", "interface", "enum"]
include_classes = true
include_methods = true
exclude_overrides = true
class_lookback_chars = 500
method_lookback_chars = 300

[code_entropy.java.strategy.glossary]
# 语义词典使用策略。
# configured_only 表示只信任显式配置的词典，不自动收编新词。
mode = "configured_only"
# 缺少 glossary 时的运行策略。
# term_gap_only：只让“术语缺口”继续计分，“命名概念冲突”标记为待配置。
# all_pending：依赖 glossary 的规则都不计分，只保留状态类规则。
# all_scored：兼容模式，允许依赖 glossary 的规则继续给分；生产默认不要改。
missing_glossary_policy = "term_gap_only"
min_term_length = 4
# variant_threshold 为历史兼容字段，当前“命名非标准占比”主评分不再直接使用它。
# 现行口径只看标准命名与非标准命名的实际命中占比。
variant_threshold = 1
ignore_terms = ["Controller", "Service", "Repository", "Mapper", "Request", "Response", "DTO", "VO", "Entity", "Config", "Util"]

[code_entropy.java.strategy.glossary.term_gap]
# term gap 候选词提取策略。
# 这里控制“哪些词会进入术语缺口候选池”。
candidate_mode = "top_unique_terms"
min_occurrences = 10
max_candidate_terms = 50
exclude_terms = ["Info", "Impl", "Data", "Field", "Enum", "Common", "Base", "Result", "Support", "List", "Item", "Page", "File", "Record", "Detail", "Rule", "Check", "Apply", "Label", "Node", "Mark", "Plan"]

[code_entropy.java.detail_export]
# detail_export 决定详情页和明细 JSON 保留多少样本。

[code_entropy.java.detail_export.limits]
# 这里只影响导出明细量，不影响评分本身。
todo_top_files = 20
todo_items = 500
knowledge_gap_items = 500
todo_preview_items = 50
todo_content_chars = 100
large_files = 100
large_methods = 200
directory_top = 50
directory_sample_files = 20
shared_common_files = 500
shared_util_files = 300
duplicate_classes = 100
duplicate_class_files = 20
glossary_terms = 100
term_variant_preview = 20
exception_types = 100
exception_files = 20
top_large_directories = 10
preferred_wrapper_preview = 3
behavior_top_error_patterns = 5
behavior_top_return_formats = 5
behavior_top_exception_types = 10
semantic_undefined_terms = 50
semantic_top_inconsistent = 10
semantic_variant_samples = 5
cycle_groups = 20
cycle_edges = 30
cycle_classes = 50

[code_entropy.java.detectors]
# detectors 定义五类熵原始事实怎么被识别出来。

[code_entropy.java.detectors.structure]

[code_entropy.java.detectors.structure.shared_buckets]
# 结构熵共享桶识别口径。
# 这是项目定制强相关区域，换项目时最容易需要人工校准。
# match_mode=segment 表示按路径段精确匹配；contains 表示只要路径包含关键字就算。
match_mode = "segment"
# shared_aliases / utility_aliases：按目录段名称识别，例如命中 common、utils 这类包段。
shared_aliases = ["common", "commons"]
utility_aliases = ["util", "utils"]
# shared_path_prefixes / utility_path_prefixes：按相对项目根目录的路径前缀强约束识别。
# 适合你已经明确知道“哪些包路径就是公共承载层/工具层”的项目。
# 例子：["src/main/java/com/company/common", "src/main/java/com/company/utils"]
# 一旦这里配置了前缀，structure.py 会优先按前缀识别；只有留空时才回退到 aliases。
# 当前这版先只收 BPC 仓库里“明显是 dedicated common/util 根包”的路径，
# 不把 dto/.../common、controller/.../common 这类上下文子包混进共享桶。
shared_path_prefixes = [
  "bpc-base/bpc-base-common/src/main/java/com/iwhalecloud/dict/bpc/base/common",
]
utility_path_prefixes = [
  "bpc-base/bpc-base-client/src/main/java/com/iwhalecloud/dict/bpc/base/client/bcmc/util",
  "bpc-base/bpc-base-datasource/src/main/java/com/iwhalecloud/dict/bpc/base/datasource/utils",
  "bpc-base/bpc-base-web/src/main/java/com/iwhalecloud/dict/bpc/base/web/utils",
  "bpc-gateway/bpc-gateway-server/src/main/java/com/iwhalecloud/dict/bpc/gateway/util",
  "bpc-group/bpc-group-prov-server/src/main/java/com/iwhalecloud/dict/bpc/group/prov/utils",
  "bpc-manage/bpc-manage-boot/src/main/java/com/iwhalecloud/bss/cele/util",
  "bpc-manage/bpc-manage-client/src/main/java/com/iwhalecloud/dict/bpc/util",
  "bpc-manage/bpc-manage-project-server/src/main/java/com/iwhalecloud/dict/bpc/manage/project/utils",
  "bpc-manage-bpm/bpc-manage-bpm-boot/src/main/java/com/iwhalecloud/bss/cele/util",
  "bpc-manage-bpm/bpc-manage-bpm-client/src/main/java/com/iwhalecloud/dict/bpm/manage/client/util",
  "bpc-manage-bpm/bpc-manage-bpm-project-server/src/main/java/com/iwhalecloud/dict/bpm/manage/project/utils",
  "bpc-operation/bpc-operation-client/src/main/java/com/iwhalecloud/dict/bpc/operation/client/utils",
  "bpc-operation/bpc-operation-data-server/src/main/java/com/iwhalecloud/dict/bpc/operation/util",
]

[code_entropy.java.detectors.structure.directory_distribution]
# 目录分布检测参数。
# oversized_dir_file_threshold: 一个目录有多少文件才算“超大目录”
# top_n_concentration_count: 前多少个头部目录参与集中度计算
oversized_dir_file_threshold = 20
top_n_concentration_count = 5

[code_entropy.java.detectors.semantic]

[code_entropy.java.detectors.semantic.term_extraction]
# scan_targets 控制从文件名、类名还是两者提取术语。
# Java 项目默认建议只统计 class_name，避免 file_stem 与类名重复计数。
scan_targets = ["class_name"]
token_patterns = ["[A-Z][a-z0-9]+"]
# naming_ignore_class_suffixes 用来给 suffix 家族降噪，例如 Job / Task / Work。
# 只有命名概念冲突在做 suffix 匹配时才会忽略这些包装类后缀，不影响前缀家族。
naming_ignore_class_suffixes = ["DTO", "VO", "DO", "Req", "Resp", "Request", "Response"]

[code_entropy.java.detectors.semantic.state_detection]
# 状态承载体重复检测：先找“状态承载体”，再抽“状态项”，最后按重合度聚成重复簇。
# carrier_name_patterns：哪些类名 / 枚举名会被当成状态承载体，例如 XxxStatus / XxxState。
carrier_name_patterns = ["(?:^|.*)(?:Status|State)(?:.*|$)"]
# constant_field_pattern：在 class 型状态承载体里，提取 public static final 常量名与右值。
constant_field_pattern = "\\b(?:(?:public|protected|private|static|final|transient|volatile)\\s+){1,8}[A-Za-z_][\\w<>\\[\\].?]*\\s+([A-Z][A-Z0-9_]{2,})\\s*=\\s*([^;]+);"
# string_literal_pattern / numeric_literal_pattern：当常量名不足以表达状态项时，用右值补充归一化。
string_literal_pattern = "\"([A-Za-z][A-Za-z0-9_:-]*)\""
numeric_literal_pattern = "\\b(\\d+)\\b"
# strip_prefixes / strip_suffixes：归一化状态项时去掉的通用前后缀。
# 例如 STATUS_DRAFT / DRAFT_STATUS / DRAFT_CODE 最终都会收敛成 DRAFT。
strip_prefixes = ["STATUS_", "STATE_"]
strip_suffixes = ["_STATUS", "_STATE", "_CODE", "_VALUE"]
# ignore_item_patterns：归一化后直接忽略的状态项模式。
# 这里先压掉 CD_1 / CD_2 / ... 这类模板编码，避免它们被误当成真实业务状态重复。
ignore_item_patterns = ["^CD_\\d+$"]
# min_carrier_items：一个状态载体至少抽到多少个状态项，才纳入统计。
min_carrier_items = 2
# min_shared_items：两个状态载体至少共享多少个状态项，才有资格判重。
min_shared_items = 2
# similarity_threshold：重复判定阈值，当前使用 overlap coefficient = shared / min(len(a), len(b))。
similarity_threshold = 0.8
# cluster_sample_limit：详情页最多展示多少组重复簇与每簇样例。
cluster_sample_limit = 10

# scatter_sample_limit：每个状态值最多内嵌多少个样例位置；问题表和定位表本身展示全部。
scatter_sample_limit = 20

# hardcoded_context_patterns：命中这些上下文字段名的字符串字面量，会按状态值散落候选统计。
hardcoded_context_patterns = ["(?i)\\b(?:status|state|statusCd|statusCode|stateCd|stateCode)\\b"]

[code_entropy.java.detectors.behavior]

[code_entropy.java.detectors.behavior.error_patterns]
# 错误处理模式识别正则。
throw_exception = "throw\\s+new\\s+\\w+Exception"
return_null = "return\\s+null"
return_error_code = "return\\s+(-?\\d+|ERROR_\\w+)"
try_catch = "try\\s*\\{[\\s\\S]*?\\}\\s*catch"
log_error = "log\\.(error|warn|debug)\\s*\\("

[code_entropy.java.detectors.behavior.return_patterns]
# 返回模式识别正则。
string_literal_pattern = "return\\s+\"[^\"]*\""
boolean_literal_pattern = "return\\s+(?:true|false)\\b"
null_return_pattern = "return\\s+null\\b"
named_reference_pattern = "return\\s+[A-Za-z_]\\w*\\s*;"
exception_pattern = "throw\\s+new\\s+(\\w+Exception)"

[code_entropy.java.detectors.behavior.wrapped_error_responses]
# 错误包装返回的静态工厂方法名。
method_names = ["error", "fail", "failure", "failed", "badRequest", "serverError", "forbidden", "unauthorized"]
include_return_only = true

[code_entropy.java.detectors.behavior.business_exceptions]
# 行为熵“业务异常未收敛”使用的标准业务异常集合。
# 任意 Java 项目可以在这里配置团队认可的业务异常边界；未配置时默认使用 BusinessException。
standard_types = ["BusinessException", "BcmcBusinessException", "BpcRiskBusinessException"]
name_patterns = ["BusinessException$", "BizException$", "BssException$", "ServiceException$"]

[code_entropy.java.detectors.cognition]
# 认知熵相关 detector。
owner_patterns = [
  "@\\w+",
  "(?i)owner\\s*[:=]\\s*[\\w.-]+",
  "(?i)assignee\\s*[:=]\\s*[\\w.-]+",
  "(?i)handler\\s*[:=]\\s*[\\w.-]+",
  "(?i)maintainer\\s*[:=]\\s*[\\w.-]+",
  "(?i)responsible\\s*[:=]\\s*[\\w.-]+",
  "(?i)by\\s*[:=]\\s*[\\w.-]+",
  "(?i)user\\s*[:=]\\s*[\\w.-]+",
  "(?i)负责人\\s*[:：]\\s*\\S+",
  "(?i)责任人\\s*[:：]\\s*\\S+",
  "(?i)处理人\\s*[:：]\\s*\\S+",
  "(?i)维护人\\s*[:：]\\s*\\S+",
  "(?i)跟进人\\s*[:：]\\s*\\S+",
  "(?i)经办人\\s*[:：]\\s*\\S+",
]

[code_entropy.java.detectors.cognition.debt_markers]
# 技术债标记识别正则。
todo = "//\\s*TODO[:\\s]*(.*)$"
fixme = "//\\s*FIXME[:\\s]*(.*)$"
hack = "//\\s*HACK[:\\s]*(.*)$"

[code_entropy.java.detectors.cognition.project_docs]
# 通用项目说明文档扫描配置；适用于任意 Java 项目，不绑定具体仓库目录。
enabled = true
entry_files = ["README.md", "README_CN.md", "README.zh-CN.md", "readme.md"]
doc_roots = ["docs", "doc", "readme", "wiki"]
doc_globs = ["*.md", "**/*.md", "*.adoc", "**/*.adoc"]
ignore_dirs = ["target", "build", "dist", ".git", ".idea", "node_modules", "asset", "assets", "img", "images"]
min_total_chars = 3000
min_entry_chars = 500
min_doc_files = 1
required_topics = ["项目介绍", "环境准备", "本地启动", "配置说明", "项目结构", "构建部署", "开发规范"]

[code_entropy.java.detectors.cognition.project_docs.topic_aliases]
"项目介绍" = ["项目介绍", "项目说明", "概述", "背景", "Introduction", "Overview"]
"环境准备" = ["环境准备", "环境设置", "运行环境", "JDK", "Java", "Maven", "Gradle", "Redis", "MySQL", "Nacos"]
"本地启动" = ["本地启动", "快速开始", "快速入门", "启动", "运行", "Quick Start", "Getting Started"]
"配置说明" = ["配置说明", "配置文件", "application.yml", "application.properties", "Nacos", "Config"]
"项目结构" = ["项目结构", "目录结构", "模块说明", "Module", "Architecture"]
"构建部署" = ["构建", "打包", "部署", "发布", "Docker", "CI", "Deploy"]
"开发规范" = ["开发规范", "编码规范", "贡献指南", "代码规范", "Contributing"]

[code_entropy.java.detectors.cognition.complexity]
# 复杂度和大文件/大方法判定阈值。
large_method_lines_threshold = 80
large_class_lines_threshold = 500
large_file_lines_threshold = 1500
large_file_warning_threshold = 2000
large_file_danger_threshold = 3000
complex_method_branch_threshold = 10
complex_method_nesting_threshold = 4
method_signature_pattern = "(?P<visibility>public|private|protected)?\\s*(?:(?:static|final|abstract|synchronized|native|default)\\s+)*(?:<[^>]+>\\s*)?(?:[\\w\\[\\].<>?,]+)\\s+(?P<name>\\w+)\\s*\\([^;{}]*\\)\\s*(?:throws[^{]+)?\\{"

[code_entropy.java.detectors.style]
# 风格熵 detector。
# 当前风格熵生产口径统一使用 Checkstyle 扫描结果。
# 旧版自研“命名一致性/格式一致性/注释密度”不再参与主评分。

[code_entropy.java.detectors.style.checkstyle]
enabled = true
mode = "auto"
# Runtime JDK 1.8 走 jdk8；高于 1.8 走 jdk17。
java_version_policy = "jdk8_or_jdk17"
jdk8_jar = "entropy_audit/lang/java/tools/checkstyle/jdk8/checkstyle-8.17-all.jar"
jdk8_config = "entropy_audit/lang/java/tools/checkstyle/jdk8/checkstyle.xml"
jdk8_workdir = "entropy_audit/lang/java/tools/checkstyle/jdk8"
jdk17_jar = "entropy_audit/lang/java/tools/checkstyle/jdk17/checkstyle-10.21.3-all.jar"
jdk17_config = "entropy_audit/lang/java/tools/checkstyle/jdk17/checkstyle.xml"
jdk17_workdir = "entropy_audit/lang/java/tools/checkstyle/jdk17"
output_format = "xml"
include_severities = ["error", "warning"]
scan_extensions = [".java"]
unknown_module_category = "style_code_smell"
exclude_modules = [
  "BeforeExecutionExclusionFileFilter",
  "SeverityMatchFilter",
  "SuppressionFilter",
  "SuppressionCommentFilter",
  "SuppressWithNearbyCommentFilter",
  "AnnotationOnSameLine",
  "MissingCtor",
  "FinalParameters",
  "RegexpSingleline",
]

[code_entropy.java.detectors.style.checkstyle.categories.style_formatting]
label = "格式排版问题"
description = "缩进、空白、换行、括号、空块等文本排版问题。"
modules = [
  "Header",
  "RegexpHeader",
  "FileTabCharacter",
  "EmptyForInitializerPad",
  "EmptyForIteratorPad",
  "GenericWhitespace",
  "MethodParamPad",
  "NoLineWrap",
  "NoWhitespaceBefore",
  "NoWhitespaceAfter",
  "ParenPad",
  "SeparatorWrap",
  "TypecastParenPad",
  "WhitespaceAfter",
  "WhitespaceAround",
  "NeedBraces",
  "EmptyBlock",
]

[code_entropy.java.detectors.style.checkstyle.categories.style_naming]
label = "命名规范问题"
description = "类名、方法名、包名、泛型参数、静态变量等命名不符合约定。"
modules = [
  "ClassTypeParameterName",
  "InterfaceTypeParameterName",
  "LocalFinalVariableName",
  "MethodName",
  "MethodTypeParameterName",
  "PackageName",
  "StaticVariableName",
  "TypeName",
  "OuterTypeFilename",
  "RegexpOnFilename",
]

[code_entropy.java.detectors.style.checkstyle.categories.style_import]
label = "导入规范问题"
description = "星号导入、非法导入、冗余导入、未使用导入等引用清洁度问题。"
modules = ["AvoidStarImport", "IllegalImport", "RedundantImport", "UnusedImports"]

[code_entropy.java.detectors.style.checkstyle.categories.style_declaration]
label = "注解与声明规范问题"
description = "注解位置、Override、包注解、修饰符顺序、顶层类数量等声明规范问题。"
modules = [
  "AnnotationLocation",
  "AnnotationUseStyle",
  "MissingOverride",
  "PackageAnnotation",
  "ModifierOrder",
  "OneTopLevelClass",
  "OuterTypeNumber",
  "InnerTypeLast",
]

[code_entropy.java.detectors.style.checkstyle.categories.style_code_smell]
label = "编码坏味道问题"
description = "空 catch、直接打印、字符串比较、equals/hashCode、控制变量修改等可维护性问题。"
modules = [
  "AvoidNestedBlocks",
  "EmptyCatchBlock",
  "CovariantEquals",
  "DefaultComesLast",
  "EmptyStatement",
  "EqualsAvoidNull",
  "EqualsHashCode",
  "IllegalInstantiation",
  "IllegalThrows",
  "IllegalTokenText",
  "IllegalType",
  "InnerAssignment",
  "MissingSwitchDefault",
  "ModifiedControlVariable",
  "MultipleVariableDeclarations",
  "NoFinalizer",
  "OneStatementPerLine",
  "SimplifyBooleanExpression",
  "SimplifyBooleanReturn",
  "StringLiteralEquality",
  "SuperClone",
  "SuperFinalize",
  "ArrayTypeStyle",
  "AvoidEscapedUnicodeCharacters",
  "DescendantToken",
  "RegexpSinglelineJava",
  "FinalClass",
  "InterfaceIsType",
]

[code_entropy.java.detectors.style.checkstyle.categories.style_complexity]
label = "复杂度与规模问题"
description = "文件过长、嵌套过深、布尔表达式复杂、参数过多等理解成本问题。"
modules = [
  "FileLength",
  "NestedForDepth",
  "NestedIfDepth",
  "NestedTryDepth",
  "BooleanExpressionComplexity",
  "ParameterNumber",
]

