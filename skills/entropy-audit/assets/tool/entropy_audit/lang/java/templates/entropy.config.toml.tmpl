# =========================================
# 认知熵
# 关注技术债、知识缺口、复杂方法与大文件负担。
# 代表团队理解和维护代码的心智负担。
# =========================================
label = "认知熵"
enabled = true
formula_version = "java-cognition-scorecard-v3"
internal_scale = 100.0
display_scale = 100.0
display_round_digits = 1
coverage_round_digits = 3
score_direction = "higher_is_worse"
aggregation = "fixed_weighted_average"

[code_entropy.scoring_v1.dimensions.cognition.level_bands]
excellent = 40.0
good = 60.0
warning = 80.0

[code_entropy.scoring_v1.dimensions.cognition.metrics]

[code_entropy.scoring_v1.dimensions.cognition.metrics.todo_density_per_k_files]
label = "每千文件债务标记数"
category = "general"
enabled = true
formula = "div(facts.todo_count * 1000, facts.total_files, 0)"
formula_cn = "(todo_count * 1000) / total_files"
meaning_cn = "把 TODO/FIXME/HACK 从绝对值改为密度，更适合跨周期比较。"
unit = "count_per_k_files"
round_digits = 3
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.cognition.metrics.unowned_debt_ratio]
label = "未归属债务比例"
category = "general"
enabled = true
formula = "div(facts.unowned_todo_count, facts.todo_count, 0)"
formula_cn = "unowned_todo_count / todo_count"
meaning_cn = "已经标出来的技术债里，没有责任人的比例；值越高越容易长期滞留。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.cognition.metrics.public_knowledge_gap_ratio]
label = "公共知识缺口比例"
category = "custom"
enabled = true
formula = "one_minus(div(facts.knowledge_documented_count, facts.knowledge_target_count, 1))"
formula_cn = "1 - (knowledge_documented_count / knowledge_target_count)"
meaning_cn = "公共类和公共方法缺少 JavaDoc 的比例；值越高越依赖口头知识。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.cognition.metrics.complex_method_ratio]
label = "复杂方法比例"
category = "general"
enabled = true
formula = "div(facts.complex_method_count, facts.total_methods, 0)"
formula_cn = "complex_method_count / total_methods"
meaning_cn = "方法体过长、分支过多或嵌套过深的方法占比；值越高越难读、难改、难测。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.cognition.metrics.large_file_class_burden_ratio]
label = "大文件/大类负担比例"
category = "general"
enabled = true
formula = "div(facts.large_file_class_count, facts.total_files, 0)"
formula_cn = "large_file_class_count / total_files"
meaning_cn = "物理总行数超过大文件阈值的 Java 文件占比；值越高说明阅读入口越沉重。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.cognition.metrics.project_doc_gap_ratio]
label = "项目文档缺口比例"
category = "general"
enabled = true
formula = "one_minus(facts.project_doc_quality_score)"
formula_cn = "1 - project_doc_quality_score"
meaning_cn = "README、docs/readme/wiki 等项目说明文档的可用度缺口；值越高说明新人理解项目越依赖口头传递。"
