# 行为熵
# 关注错误处理、返回契约、异常类型扩散。
# 与 controller 检测、返回包装识别配置强相关。
# =========================================
label = "行为熵"
enabled = true
formula_version = "java-behavior-scorecard-v2-light-ast"
internal_scale = 100.0
display_scale = 100.0
display_round_digits = 1
coverage_round_digits = 3
score_direction = "higher_is_worse"
aggregation = "fixed_weighted_average"

[code_entropy.scoring_v1.dimensions.behavior.level_bands]
excellent = 40.0
good = 60.0
warning = 80.0

[code_entropy.scoring_v1.dimensions.behavior.metrics]

[code_entropy.scoring_v1.dimensions.behavior.metrics.failure_strategy_split_ratio]
label = "失败处理策略分裂比例"
category = "general"
enabled = true
formula = "one_minus(div(facts.failure_strategy_dominant_count, facts.failure_strategy_total_count, 1))"
formula_cn = "1 - failure_strategy_dominant_count / failure_strategy_total_count"
meaning_cn = "按 catch 块把失败处理归为重新抛异常、包装错误返回、返回 null、吞异常等策略；主导策略占比越低，失败路径越分裂。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.behavior.metrics.swallowed_exception_ratio]
label = "吞异常比例"
category = "general"
enabled = true
formula = "div(facts.swallowed_catch_count, facts.catch_block_count, 0)"
formula_cn = "swallowed_catch_count / catch_block_count"
meaning_cn = "统计 catch 块中空处理、只打日志或没有 throw/return 失败处理的比例。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.behavior.metrics.error_return_contract_mix_ratio]
label = "返回错误契约混用比例"
category = "custom"
enabled = true
formula = "one_minus(div(facts.error_return_contract_dominant_count, facts.error_return_contract_total_count, 1))"
formula_cn = "1 - error_return_contract_dominant_count / error_return_contract_total_count"
meaning_cn = "只统计 Controller/API 层失败返回契约，判断包装错误、return null、错误码、字符串、布尔值、直接抛异常是否混用。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.behavior.metrics.generic_exception_throw_ratio]
label = "泛化异常抛出比例"
category = "general"
enabled = true
formula = "div(facts.generic_exception_throw_count, facts.exception_throw_count, 0)"
formula_cn = "generic_exception_throw_count / exception_throw_count"
meaning_cn = "统计 throw new Exception、RuntimeException、Throwable 这类缺少业务语义的泛化异常占比。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.behavior.metrics.business_exception_convergence_gap]
label = "业务异常未收敛比例"
category = "custom"
enabled = true
formula = "div(facts.nonstandard_business_exception_throw_count, facts.business_exception_throw_count, 0)"
formula_cn = "nonstandard_business_exception_throw_count / business_exception_throw_count"
meaning_cn = "把业务异常与配置的标准业务异常基类对齐；非标准业务异常占比越高，说明异常语义越容易局部生长。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

