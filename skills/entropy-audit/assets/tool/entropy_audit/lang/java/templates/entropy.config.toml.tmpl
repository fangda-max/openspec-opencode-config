value = 0.01
score = 15.0
status = "notice"
label_cn = "非标准命中占比 >= 1%"

# 语义熵规则 2：术语缺口比例
# 人话说明：
# 看高频核心术语里，有多少还没进入 glossary 词典。
# 它衡量的是“团队有没有把核心领域语言显式沉淀出来”，不是简单统计生词。
# 缺口越大，说明共享语义基础越弱。
[[code_entropy.scoring_v1.dimensions.semantic.rules]]
id = "semantic.term_gap_ratio"
label = "术语缺口比例"
category = "custom"
state = "scored"
metric = "term_gap_ratio"
weight = 45.0
direction = "higher_is_worse"
score_if_no_match = 0.0
score_if_missing = 45.0
rule_cn = "核心命名越多落在词典外，团队共享语义就越弱。"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">="
value = 0.85
score = 100.0
status = "danger"
label_cn = "核心候选缺口 >= 85%"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">="
value = 0.7
score = 80.0
status = "danger"
label_cn = "核心候选缺口 >= 70%"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">="
value = 0.55
score = 60.0
status = "warning"
label_cn = "核心候选缺口 >= 55%"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">="
value = 0.4
score = 35.0
status = "notice"
label_cn = "核心候选缺口 >= 40%"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">="
value = 0.25
score = 15.0
status = "notice"
label_cn = "核心候选缺口 >= 25%"

# 语义熵规则 3：状态承载体重复比
# 人话说明：
# 看状态语义是不是由多个 Status / State 承载体重复维护。
# 例如多个 Status / State 枚举、常量类并行生长，容易导致协议和行为不一致。
# 一旦这里开始重复，后续维护和联调成本通常会明显上升。
[[code_entropy.scoring_v1.dimensions.semantic.rules]]
id = "semantic.state_duplicate_ratio"
label = "状态承载体重复比"
category = "custom"
state = "scored"
metric = "state_duplicate_ratio"
weight = 10.0
direction = "higher_is_worse"
score_if_no_match = 0.0
score_if_missing = 30.0
rule_cn = "多个 Status/State 承载体维护相似状态集，会让协议和行为约定持续分叉。"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">="
value = 0.3
score = 100.0
status = "danger"
label_cn = "重复 >= 30%"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">="
value = 0.15
score = 70.0
status = "warning"
label_cn = "重复 >= 15%"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">"
value = 0.0
score = 35.0
status = "notice"
label_cn = "存在重复"

# 语义熵规则 4：状态值散落比例
# 人话说明：
# 看状态值是不是直接散落在 service/controller/mapper 判断里。
# 硬编码状态值越多，越说明状态语义没有从统一枚举或常量源引用。
[[code_entropy.scoring_v1.dimensions.semantic.rules]]
id = "semantic.state_value_scatter_ratio"
label = "状态值散落比例"
category = "custom"
state = "scored"
metric = "state_value_scatter_ratio"
weight = 10.0
direction = "higher_is_worse"
score_if_no_match = 0.0
score_if_missing = 25.0
rule_cn = "状态值散落在业务代码中，会让状态语义难以统一治理和回查。"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">="
value = 0.3
score = 100.0
status = "danger"
label_cn = "存在散落"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">="
value = 0.15
score = 70.0
status = "warning"
label_cn = "存在散落"

[[code_entropy.scoring_v1.dimensions.semantic.rules.bands]]
op = ">"
value = 0.0
score = 35.0
status = "notice"
label_cn = "存在散落"

