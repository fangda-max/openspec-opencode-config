# =========================================
# BPC_V2 熵审计总配置
# 这份文件是当前仓库的单一主配置入口。
# 主要分为三层：
# 1. 项目基础配置：project / scope / paths
# 2. 代码本体熵配置：code_entropy.*
# =========================================

# 项目基础信息。
[project]
# 项目标识，建议稳定不变，供报表和历史快照识别。
id = {{PROJECT_ID}}
# 项目展示名。
name = {{PROJECT_NAME}}
# 当前项目语言，决定走哪套语言适配器。
language = "java"

# 关键业务流与扫描边界。
[scope]
# 关键业务流名称，供代码本体熵报告标识项目范围。
critical_flows = {{CRITICAL_FLOWS}}
# 仓库内文档路径提示。
[paths]
architecture = {{ARCHITECTURE_PATHS}}
runbooks = {{RUNBOOK_PATHS}}
plans = {{PLAN_PATHS}}


# =========================================
# 代码本体熵总开关
# exclude_dirs / include_extensions 直接影响扫描输入边界。
# internal_package_prefixes 用来判断内部包与外部依赖。
# =========================================
[code_entropy]
# 是否启用代码本体熵整条链路。
enabled = true
# 扫描时忽略的目录。
exclude_dirs = {{EXCLUDE_DIRS}}
# 当前 Java 内置 analyzer 只支持 .java。
include_extensions = [".java"]
# 内部包名前缀，供依赖、行为和项目画像判断内部代码使用。
internal_package_prefixes = {{INTERNAL_PACKAGE_PREFIXES}}

# =========================================
# 代码本体熵评分总配置
# 所有五类熵都统一走 scoring_v1。
# 这里的 v1 是“当前生产主口径”，不是旧版残留。
# =========================================
[code_entropy.scoring_v1]
# 评分引擎总开关。
enabled = true
# schema 版本，控制配置结构是否兼容。
schema_version = "code-entropy-scoring-v1-draft1"
# 总评分口径版本；五类熵任一结构性变化都应同步评估是否升版。
formula_version = "java-code-entropy-scorecard-v1-p8"
# 当前已经迁入统一评分引擎的维度列表。
migrated_dimensions = ["structure", "semantic", "behavior", "cognition", "style"]

# 默认评分显示与聚合口径。
[code_entropy.scoring_v1.defaults]
# 内部计算分值范围。
internal_scale = 100.0
# 对外展示分值范围。
display_scale = 100.0
# 最终展示分保留小数位。
display_round_digits = 1
# 覆盖率显示保留位数。
coverage_round_digits = 3
# 分值方向：higher_is_worse 表示分越高风险越大。
score_direction = "higher_is_worse"
# 聚合方式：固定权重加权平均。
aggregation = "fixed_weighted_average"

# 五类熵维度都定义在 dimensions 下。
[code_entropy.scoring_v1.dimensions]

# =========================================
# 结构熵
# 关注目录承载、共享桶膨胀、头部目录集中和目录粒度。
# 这是当前结构熵生产版主口径。
# =========================================
[code_entropy.scoring_v1.dimensions.structure]
label = "结构熵"
enabled = true
# 结构熵单独的公式版本；只要结构熵规则/权重/原始输入语义变化，就应考虑升版。
formula_version = "java-structure-scorecard-v1-p3"
internal_scale = 100.0
display_scale = 100.0
display_round_digits = 1
coverage_round_digits = 3
score_direction = "higher_is_worse"
aggregation = "fixed_weighted_average"

[code_entropy.scoring_v1.dimensions.structure.level_bands]
# 总分等级阈值：<excellent 为优秀，<good 为良好，<warning 为预警，其余为危险。
excellent = 40.0
good = 60.0
warning = 80.0

[code_entropy.scoring_v1.dimensions.structure.metrics]

# metric 通用字段说明：
# label: 中文名
# category: general 通用规则，custom 项目定制规则
# formula / formula_cn: 指标计算公式
# meaning_cn: 指标治理含义
# when_missing: 原始值缺失时如何处理，zero=按 0 处理，null=记为缺失
[code_entropy.scoring_v1.dimensions.structure.metrics.shared_bucket_ratio]
label = "共享承载目录占比"
category = "custom"
enabled = true
formula = "div(facts.shared_bucket_total, facts.total_files, 0)"
formula_cn = "shared_bucket_total / total_files"
meaning_cn = "把人工配置的共享承载目录唯一文件总量，占全部 Java 文件的比例作为结构膨胀信号，避免 common/util 别名重叠时重复计数。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.structure.metrics.max_dir_files_ratio]
label = "最大目录文件占比"
category = "general"
enabled = true
formula = "div(facts.max_dir_files, facts.total_files, 0)"
formula_cn = "max_dir_files / total_files"
meaning_cn = "避免直接用最大目录绝对文件数，改为看单目录吞掉全仓库文件的比例。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.structure.metrics.oversized_dir_ratio]
label = "超大目录数量占比"
category = "general"
enabled = true
formula = "div(facts.oversized_dir_count, facts.total_dirs, 0)"
formula_cn = "oversized_dir_count / total_dirs"
meaning_cn = "超过超大目录阈值的目录数量，占全部目录的比例；用来识别不是单点，而是多处目录同时膨胀。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.structure.metrics.top_n_dir_concentration]
label = "前 N 大目录集中度"
category = "general"
enabled = true
formula = "div(facts.top_n_dir_file_sum, facts.total_files, 0)"
formula_cn = "top_n_dir_file_sum / total_files"
meaning_cn = "把前 N 大目录合计吞掉的文件量，占全部文件的比例；用来识别代码是否被少数目录长期垄断。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.structure.metrics.avg_files_per_dir]
label = "平均目录文件数"
category = "general"
enabled = true
formula = "div(facts.total_files, facts.total_dirs, 0)"
formula_cn = "total_files / total_dirs"
meaning_cn = "目录平均承载量，反映目录粒度是否长期失衡。"
unit = "files_per_dir"
round_digits = 2
when_missing = "zero"

# 结构熵规则 1：共享承载目录占比
# 人话说明：
# 看 common / shared / util 这类共享承载目录是否持续吸入业务代码。
# 这类目录占比越高，说明业务边界越容易被抽空到“公共桶”里。
# 这是结构熵里最直接的边界回流信号。
[[code_entropy.scoring_v1.dimensions.structure.rules]]
# rule 通用字段说明：
# state=scored 表示参与正式评分
# metric 指向上方定义的 metric
# weight 为该规则在本维度中的权重预算
# score_if_no_match 为未命中任何 band 时的分数
# score_if_missing 为原始值缺失时的兜底分数
id = "structure.shared_bucket_ratio"
label = "共享承载目录占比"
category = "custom"
state = "scored"
metric = "shared_bucket_ratio"
weight = 29.412
direction = "higher_is_worse"
score_if_no_match = 0.0
score_if_missing = 60.0
rule_cn = "共享目录占比越高，越说明业务边界持续向 common/util 聚集。"

