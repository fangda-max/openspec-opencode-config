[code_entropy.scoring_v1.dimensions.semantic]
# =========================================
# 语义熵
# 关注术语一致性、词典缺口、状态承载体重复与状态值散落。
# glossary 与 term_gap 配置会显著影响本维度结果。
# =========================================
label = "语义熵"
enabled = true
formula_version = "java-semantic-scorecard-v1-p8"
internal_scale = 100.0
display_scale = 100.0
display_round_digits = 1
coverage_round_digits = 3
score_direction = "higher_is_worse"
aggregation = "fixed_weighted_average"

[code_entropy.scoring_v1.dimensions.semantic.level_bands]
excellent = 40.0
good = 60.0
warning = 80.0

[code_entropy.scoring_v1.dimensions.semantic.metrics]

[code_entropy.scoring_v1.dimensions.semantic.metrics.naming_inconsistency_ratio]
label = "命名非标准占比"
category = "custom"
enabled = true
formula = "div(facts.naming_nonstandard_hit_count, facts.naming_matched_hit_count, 0)"
formula_cn = "naming_nonstandard_hit_count / naming_matched_hit_count"
meaning_cn = "在所有命中 glossary 术语家族的类名里，统计非标准命名的命中占比；标准名不扣分，SaleOpp / Opportunity 这类变体命中会进入分子。"
unit = "ratio"
round_digits = 4
when_missing = "null"

[code_entropy.scoring_v1.dimensions.semantic.metrics.term_gap_ratio]
label = "术语缺口比例"
category = "custom"
enabled = true
formula = "div(facts.undefined_term_count, facts.total_terms, 0)"
formula_cn = "undefined_term_count / total_terms"
meaning_cn = "从高频唯一术语候选池中，计算未进入被扫描项目 glossary.md 标准词/别名 token 的比例；缺少项目 glossary.md 时按最高风险计分。"
unit = "ratio"
round_digits = 4
when_missing = "null"

[code_entropy.scoring_v1.dimensions.semantic.metrics.state_duplicate_ratio]
label = "状态承载体重复比"
category = "custom"
enabled = true
formula = "div(facts.duplicate_state_count, facts.state_count, 0)"
formula_cn = "duplicate_state_count / state_count"
meaning_cn = "把重复簇中除保留 1 个以外的冗余 Status/State 枚举或常量类数量，折算为全部状态承载体数量的比例。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

[code_entropy.scoring_v1.dimensions.semantic.metrics.state_value_scatter_ratio]
label = "状态值散落比例"
category = "custom"
enabled = true
formula = "div(facts.scattered_state_value_count, facts.state_value_reference_count, 0)"
formula_cn = "scattered_state_value_count / state_value_reference_count"
meaning_cn = "统计状态上下文中直接硬编码的状态字面量，占状态承载体定义项与硬编码引用总量的比例；用于定位状态值散落在业务代码中的语义熵。"
unit = "ratio"
round_digits = 4
when_missing = "zero"

